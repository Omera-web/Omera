# Copiez ce fichier en `.env` ou `.env.local` sur votre machine / hébergeur (Vercel : Variables d'environnement).
# Ne commitez JAMAIS le fichier `.env` réel.

# Anthropic — génération de la page d'accueil de préview (api/preview-home.js)
ANTHROPIC_API_KEY=

# Optionnel — modèle (défaut : Haiku pour limiter les coûts)
# ANTHROPIC_MODEL=claude-3-5-haiku-20241022
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Resend — même variables que api/contact.js (obligatoire pour les mails du site)
# Utilisé par api/contact.js et api/preview-notify.js (mail + HTML en PJ à chaque nouvelle préview)
# RESEND_API_KEY=
# RECEIVER_EMAIL=contact.omerafrance@gmail.com
